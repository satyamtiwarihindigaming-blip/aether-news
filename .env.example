# ==========================================================================
# AETHERNEWS - Environment Configuration Example
# Copy this file to '.env' and fill in your credentials.
# Do not commit your actual '.env' file containing secrets to GitHub!
# ==========================================================================

# 1. Google Gemini API (Free LLM rewriter key)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Supabase Connection (PostgreSQL Database client credentials)
# Get credentials from your project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your-supabase-anon-key-here

# 3. Cloudinary CDN (Free image hosting API credentials)
# Get credentials from your Cloudinary Console dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# 4. Telegram Alerts (Optional)
# Get BOT Token from @BotFather, Chat ID by forwarding message to @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# 5. Frontend Site Configurations (Optional)
# Used to generate correct dynamic share URLs in Telegram
NEXT_PUBLIC_SITE_URL=https://aether-news.vercel.app

# 6. Admin Panel password (Optional, defaults to 'admin123')
NEXT_PUBLIC_ADMIN_PASSWORD=admin123
